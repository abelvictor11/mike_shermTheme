{%- doc -%}
  Button with animated brush stroke effect.
  The brush stroke animates when the button enters the viewport.

  @param {string} label - Button text
  @param {string} link - Button link URL
  @param {boolean} [new_tab] - Open in new tab
  @param {object} [block] - The block object for Shopify attributes

  @example
  {% render 'button-brush', label: 'View Dates', link: '/pages/tour' %}
{%- enddoc -%}

{{ 'button-brush.css' | asset_url | stylesheet_tag }}

<a
  {% if link == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ link }}"
  {% endif %}
  class="button-brush"
  data-button-brush
  {%- if new_tab -%}
    target="_blank"
    rel="noopener noreferrer"
  {%- endif -%}
  {% if block %}{{ block.shopify_attributes }}{% endif %}
>
  <span class="button-brush__text">{{ label }}</span>
  <span class="button-brush__stroke" aria-hidden="true">
    <svg viewBox="0 0 300 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Main ellipse stroke -->
      <path d="M 20,50 
               C 20,25 60,10 150,10 
               C 240,10 280,25 280,50 
               C 280,75 240,90 150,90 
               C 60,90 20,75 20,50 
               C 20,30 70,15 150,15
               C 230,15 275,30 275,50
               C 275,70 230,85 150,85
               C 70,85 25,70 25,50" />
      <!-- Secondary stroke for texture -->
      <path d="M 25,48 
               C 30,28 75,12 150,12 
               C 225,12 270,28 275,48 
               C 280,68 235,88 150,88 
               C 65,88 20,68 25,48" />
      <!-- Third stroke for more texture -->
      <path d="M 18,52 
               C 18,30 65,8 150,8 
               C 235,8 282,30 282,52 
               C 282,74 235,92 150,92 
               C 65,92 18,74 18,52" />
    </svg>
  </span>
</a>

<script>
  (function() {
    // Initialize Intersection Observer for brush button animation
    if ('IntersectionObserver' in window) {
      const brushButtons = document.querySelectorAll('[data-button-brush]');
      
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      }, {
        threshold: 0.3,
        rootMargin: '0px 0px -50px 0px'
      });

      brushButtons.forEach(button => {
        observer.observe(button);
      });
    } else {
      // Fallback for browsers without IntersectionObserver
      document.querySelectorAll('[data-button-brush]').forEach(button => {
        button.classList.add('is-visible');
      });
    }
  })();
</script>
